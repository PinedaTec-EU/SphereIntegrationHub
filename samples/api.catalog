- version: 3.11
  plugins:
  - id: http
    contractVersion: "1.0"
    runtimeVersion: "1.0"
  - id: openai
    contractVersion: "1.0"
    runtimeVersion: "1.0"
  latencyProfiles:
  - name: semaphore-default
    bands:
    - name: green
      minMs: 0
      maxMs: 200
      color: green
      label: normal
    - name: amber
      minMs: 201
      maxMs: 500
      color: amber
      label: degraded
    - name: red
      minMs: 501
      color: red
      label: slow
  definitions:
  - name: accounts
    contractType: openapi
    latencyProfile: semaphore-default
    basePath: /api/accounts
    openApiUrl: /swagger/v1/swagger.json
    healthCheck: /health
    readiness:
      maxRetries: 12
      delayMs: 5000
      timeoutMs: 2000
      httpStatus:
      - 200
      - 204
    baseUrl:
      local: http://localhost:5000
      pre: https://pre.api.example.com
      prod: https://api.example.com
  - name: mcp
    basePath: /
    baseUrl:
      local: http://localhost:5100
  connections:
  - name: openai-main
    type: llm
    provider: openai
    baseUrl:
      local: https://api.openai.com/v1
    apiKeySecret: "{{input.openaiApiKey}}"
