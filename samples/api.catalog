- version: 3.11
  plugins:
  - id: http
    contractVersion: "1.0"
    runtimeVersion: "1.0"
  - id: openai
    contractVersion: "1.0"
    runtimeVersion: "1.0"
  definitions:
  - name: accounts
    contractType: openapi
    basePath: /api/accounts
    openApiUrl: /swagger/v1/swagger.json
    healthCheck: /health
    readiness:
      maxRetries: 12
      delayMs: 5000
      timeoutMs: 2000
      httpStatus:
      - 200
      - 204
    baseUrl:
      local: http://localhost:5000
      pre: https://pre.api.example.com
      prod: https://api.example.com
  - name: mcp
    basePath: /
    baseUrl:
      local: http://localhost:5100
  connections:
  - name: openai-main
    type: llm
    provider: openai
    baseUrl:
      local: https://api.openai.com/v1
    apiKeySecret: "{{input.openaiApiKey}}"
